# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://ddotsjobs.com
NEXTAUTH_URL=https://ddotsjobs.com
NEXTAUTH_SECRET=
PORT=3100
NODE_ENV=production

# ── Database (isolated pg_createcluster 16 ddotsjobs, port 5436) ──
DATABASE_URL=postgresql://ddotsjobs_user:CHANGEME@localhost:5436/ddotsjobs
# PgBouncer pooled URL (transaction mode) — used by web/worker runtime
DATABASE_POOL_URL=postgresql://ddotsjobs_user:CHANGEME@localhost:6432/ddotsjobs

# ── Redis (shared instance, prefixed keys) ───────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=ddotsjobs:

# ── Meilisearch (Docker, localhost only) ─────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# ── Anthropic ────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Green API (WhatsApp) ─────────────────────────────
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ── Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Resend ───────────────────────────────────────────
RESEND_API_KEY=

# ── Cloudflare R2 ────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=ddotsjobs-assets
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.ddotsjobs.com
